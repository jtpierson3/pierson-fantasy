// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RosterSlot {
  STARTER
  SUB
  RESERVE
  IR
}

// ===================================================
//      Fantasy Football
// ===================================================

model User {
  id              String                        @id @default(cuid())
  clerkId         String                        @unique
  username        String
  email           String
  isSiteAdmin     Boolean                       @default(false)
  leagues         FantasyLeagueMember[]
  fantasyTeams    FantasyTeam[]
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  survivorLeagues SurvivorFantasyLeagueMember[]
  leagueTribe     SurvivorFantasyLeagueTribe?
}

model FantasyLeague {
  id           String                @id @default(cuid())
  name         String
  description  String?
  members      FantasyLeagueMember[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  fantasyTeams FantasyTeam[]
}

model FantasyLeagueMember {
  id              String        @id @default(cuid())
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  fantasyLeague   FantasyLeague @relation(fields: [fantasyLeagueId], references: [id])
  fantasyLeagueId String
  isAdmin         Boolean       @default(false)
  points          Int           @default(0)

  @@unique([userId, fantasyLeagueId])
}

model FantasyTeam {
  id              String              @id @default(cuid())
  name            String
  formation       String              @default("4-3-3")
  user            User                @relation(fields: [userId], references: [id])
  userId          String              @unique
  fantasyLeague   FantasyLeague       @relation(fields: [fantasyLeagueId], references: [id])
  fantasyLeagueId String
  players         FantasyTeamPlayer[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([userId, fantasyLeagueId])
}

model FantasyTeamPlayer {
  id            String      @id @default(cuid())
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  fantasyTeamId String
  player        Player      @relation(fields: [playerId], references: [id])
  playerId      Int
  rosterSlot    RosterSlot  @default(RESERVE)
  slotOrder     Int         @default(0)
  addedAt       DateTime    @default(now())

  @@unique([fantasyTeamId, playerId])
}

// ===========================================
//          Football Data Models
// ===========================================

model League {
  id         Int      @id
  name       String
  short_code String?
  image_path String
  season_id  Int
  teams      Team[]
  updatedAt  DateTime @updatedAt
}

model Team {
  id         Int      @id
  name       String
  short_code String?
  image_path String
  league     League   @relation(fields: [leagueId], references: [id])
  leagueId   Int
  players    Player[]
  updatedAt  DateTime @updatedAt
}

model Player {
  id             Int                 @id
  display_name   String
  image_path     String
  position_id    Int
  jersey_number  Int?
  date_of_birth  String?
  team           Team                @relation(fields: [teamId], references: [id])
  teamId         Int
  fantasyPlayers FantasyTeamPlayer[]
  updatedAt      DateTime            @updatedAt
}

//------------------------------ SURVIVOR ----------------------------------

model SurvivorPlayer {
  id           String       @id @default(cuid())
  name         String       @unique
  imageUrl     String?
  bio          String?
  constestants Contestant[]
}

model SurvivorSeason {
  id          String       @id @default(cuid())
  number      Int
  title       String
  imageUrl    String?
  contestants Contestant[]
  episodes    Episode[]
  tribes      Tribe[]
}

model Tribe {
  id               String            @id @default(cuid())
  name             String
  color            String
  survivorSeasonId String
  survivorSeason   SurvivorSeason    @relation(fields: [survivorSeasonId], references: [id])
  memberships      TribeMembership[]
}

model Episode {
  id               String         @id @default(cuid())
  number           Int
  name             String
  airDate          DateTime
  survivorSeasonId String
  survivorSeason   SurvivorSeason @relation(fields: [survivorSeasonId], references: [id])
  stats            EpisodeStat[]
}

model Contestant {
  id               String            @id @default(cuid())
  survivorPlayerId String
  survivorSeasonId String
  survivorPlayer   SurvivorPlayer    @relation(fields: [survivorPlayerId], references: [id])
  survivorSeason   SurvivorSeason    @relation(fields: [survivorSeasonId], references: [id])
  status           String
  tribeMemberships TribeMembership[]
  episodeStats     EpisodeStat[]
  survivorPicks    SurvivorPicks[]
}

model TribeMembership {
  id           String     @id @default(cuid())
  contestantId String
  tribeId      String
  tribeType    String
  isCurrent    Boolean    @default(true)
  contestant   Contestant @relation(fields: [contestantId], references: [id])
  tribe        Tribe      @relation(fields: [tribeId], references: [id])
}

model ScoringEvent {
  id       String        @id @default(cuid())
  label    String
  points   Int
  category String
  stats    EpisodeStat[]
}

model EpisodeStat {
  id           String       @id @default(cuid())
  episodeId    String
  contestantId String
  eventId      String
  episode      Episode      @relation(fields: [episodeId], references: [id])
  contestant   Contestant   @relation(fields: [contestantId], references: [id])
  event        ScoringEvent @relation(fields: [eventId], references: [id])
}

model SurvivorLeague {
  id        String                        @id @default(cuid())
  name      String
  members   SurvivorFantasyLeagueMember[]
  createdAt DateTime
  updatedAt DateTime
}

model SurvivorFantasyLeagueMember {
  id               String         @id @default(cuid())
  user             User           @relation(fields: [userId], references: [id])
  userId           String
  survivorLeague   SurvivorLeague @relation(fields: [survivorLeagueId], references: [id])
  survivorLeagueId String
  isAdmin          Boolean        @default(false)
  points           Int            @default(0)

  @@unique([userId, survivorLeagueId])
}

model SurvivorFantasyLeagueTribe {
  id        String          @id @default(cuid())
  name      String
  user      User            @relation(fields: [userId], references: [id])
  userId    String          @unique
  players   SurvivorPicks[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model SurvivorPicks {
  id           String                     @id @default(cuid())
  userId       String
  leagueId     String
  contestantId String
  leagueTribe  SurvivorFantasyLeagueTribe @relation(fields: [leagueId], references: [id])
  contestant   Contestant                 @relation(fields: [contestantId], references: [id])
}
